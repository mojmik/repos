<Window x:Class="mCompWardenManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="mCompWarden Management"
        Height="680" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#f3f6fa">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Label Content="Typ souboru:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="FileTypeCombo" Width="160" SelectionChanged="FileTypeCombo_SelectionChanged">
                    <ComboBoxItem Tag="v2" IsSelected="True">V2 (.cwd)</ComboBoxItem>
                    <ComboBoxItem Tag="v3">V3 (.mcw3.xml)</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <!-- V3 root setting -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" x:Name="V3RootBar" Visibility="Collapsed">
                <Label Content="defaultTimezone:" VerticalAlignment="Center" Margin="20,0,8,0"/>
                <TextBox x:Name="DefaultTimezoneText" Width="180" ToolTip="Např. Europe/Prague"/>
            </StackPanel>
        </DockPanel>

        <!-- Editors -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- V2 editor -->
            <ScrollViewer x:Name="V2Scroller" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="V2Panel" Visibility="Visible" Orientation="Vertical" Margin="0,0,0,10">
                    <Label Content="Nastavení V2 souboru" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <CheckBox Name="AllMachines" Content="All machines" VerticalAlignment="Center"/>
                        <TextBox Name="MachineNameText" Width="220" Margin="10,0,0,0" VerticalAlignment="Center" ToolTip="Konkrétní počítač (volitelné)"/>
                        <TextBox Name="UserNameText" Width="220" Margin="10,0,0,0" VerticalAlignment="Center" ToolTip="Konkrétní uživatel (volitelné)"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Content="Soubor:" Width="80"/>
                        <TextBox Name="FileNameText" Width="520"/>
                        <Button Name="genFileNameButton" Content="Generovat" Margin="10,0,0,0" Click="genFileNameButton_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Content="Repeating:" Width="80"/>
                        <TextBox Name="RepeatingText" Width="60" ToolTip="Interval (číslo)"/>
                        <ComboBox Name="RepeatingTypeCombo" Width="90" Margin="10,0,0,0" ToolTip="Jednotka"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <CheckBox Name="RemoteCheckBox" Content="Remote"/>
                        <CheckBox Name="NeedsNetworkCheckBox" Content="Needs Network" Margin="10,0,0,0"/>
                        <CheckBox Name="NeedsUserCheckBox" Content="Needs User" Margin="10,0,0,0" Checked="NeedsUserCheckBox_Checked"/>
                        <CheckBox Name="NeedsSystemCheckBox" Content="Needs System" Margin="10,0,0,0" Checked="NeedsSystemCheckBox_Checked"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Margin="0,0,0,5">
                        <Label Content="Excluded Computers"/>
                        <TextBox Name="ExcludedComputersText"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Margin="0,0,0,5">
                        <Label Content="Excluded Regex"/>
                        <TextBox Name="ExcludedComputersRegexText"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Margin="0,0,0,5">
                        <Label Content="RunAt (např. 2025-03-15 14:00)"/>
                        <TextBox Name="RunAtText"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Margin="0,0,0,5">
                        <Label Content="Příkazy (každý na nový řádek)"/>
                        <TextBox Name="commandsBox" AcceptsReturn="True" Height="140" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- V3 editor (multi-task) -->
            <Grid x:Name="V3Grid" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Task list -->
                <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                    <DockPanel Margin="8">
                        <TextBlock DockPanel.Dock="Top" Text="Úlohy (Tasks)" FontWeight="Bold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Button x:Name="AddTaskBtn" Content="Přidat" Width="70" Margin="0,0,5,0" Click="AddTask_Click"/>
                            <Button x:Name="RemoveTaskBtn" Content="Odebrat" Width="75" Margin="0,0,5,0" Click="RemoveTask_Click"/>
                            <Button x:Name="DuplicateTaskBtn" Content="Duplikovat" Width="90" Click="DuplicateTask_Click"/>
                        </StackPanel>
                        <ListBox x:Name="TaskList" DisplayMemberPath="V3Id" SelectionChanged="TaskList_SelectionChanged"/>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="10" Background="#E6E9EF"/>

                <!-- Right: Task details -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                        <Label Content="Nastavení V3 úlohy" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                        <!-- Basic task fields -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Label Content="ID:" Width="80"/>
                            <TextBox x:Name="TaskIdText" Width="200"/>
                            <CheckBox x:Name="TaskEnabledCheck" Content="enabled" Margin="15,0,0,0" IsChecked="True"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,5">
                            <Label Content="Popis (Description)"/>
                            <TextBox x:Name="TaskDescriptionText" AcceptsReturn="True" Height="60"/>
                        </StackPanel>

                        <GroupBox Header="Cílení (Target)" Margin="0,5,0,5">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Label Content="Machine:" Width="80"/>
                                    <TextBox x:Name="V3MachineText" Width="220" ToolTip="Nech prázdné nebo napiš 'all' pro všechny"/>
                                    <Label Content="User:" Width="60" Margin="12,0,0,0"/>
                                    <TextBox x:Name="V3UserText" Width="160" ToolTip="Prázdné = jakýkoli uživatel"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Run as:" Width="80"/>
                                    <ComboBox x:Name="V3RunAsCombo" Width="140">
                                        <ComboBoxItem Tag="either" IsSelected="True">Either</ComboBoxItem>
                                        <ComboBoxItem Tag="user">User (desktop)</ComboBoxItem>
                                        <ComboBoxItem Tag="system">System</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Schedule -->
                        <GroupBox Header="Plán" Margin="0,5,0,5">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Label Content="Typ:" Width="80"/>
                                    <ComboBox x:Name="V3ScheduleTypeCombo" Width="180" SelectionChanged="V3ScheduleTypeCombo_SelectionChanged">
                                        <ComboBoxItem Tag="daily"   IsSelected="True">Denně</ComboBoxItem>
                                        <ComboBoxItem Tag="weekly">Týdně</ComboBoxItem>
                                        <ComboBoxItem Tag="monthly">Měsíčně</ComboBoxItem>
                                        <ComboBoxItem Tag="hourly">Každou hodinu</ComboBoxItem>
                                        <ComboBoxItem Tag="minutely">Každé N minut</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Time (for daily/weekly/monthly) -->
                                <StackPanel x:Name="TimeBlock" Orientation="Horizontal" Margin="0,0,0,5">
                                    <Label Content="Čas:" Width="80"/>
                                    <ComboBox x:Name="HourCombo" Width="60">
                                        <ComboBoxItem>00</ComboBoxItem>
                                        <ComboBoxItem>01</ComboBoxItem>
                                        <ComboBoxItem>02</ComboBoxItem>
                                        <ComboBoxItem>03</ComboBoxItem>
                                        <ComboBoxItem>04</ComboBoxItem>
                                        <ComboBoxItem>05</ComboBoxItem>
                                        <ComboBoxItem>06</ComboBoxItem>
                                        <ComboBoxItem>07</ComboBoxItem>
                                        <ComboBoxItem>08</ComboBoxItem>
                                        <ComboBoxItem>09</ComboBoxItem>
                                        <ComboBoxItem>10</ComboBoxItem>
                                        <ComboBoxItem>11</ComboBoxItem>
                                        <ComboBoxItem>12</ComboBoxItem>
                                        <ComboBoxItem>13</ComboBoxItem>
                                        <ComboBoxItem>14</ComboBoxItem>
                                        <ComboBoxItem>15</ComboBoxItem>
                                        <ComboBoxItem>16</ComboBoxItem>
                                        <ComboBoxItem>17</ComboBoxItem>
                                        <ComboBoxItem>18</ComboBoxItem>
                                        <ComboBoxItem>19</ComboBoxItem>
                                        <ComboBoxItem>20</ComboBoxItem>
                                        <ComboBoxItem>21</ComboBoxItem>
                                        <ComboBoxItem>22</ComboBoxItem>
                                        <ComboBoxItem>23</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="MinuteCombo" Width="60">
                                        <ComboBoxItem>00</ComboBoxItem>
                                        <ComboBoxItem>05</ComboBoxItem>
                                        <ComboBoxItem>10</ComboBoxItem>
                                        <ComboBoxItem>15</ComboBoxItem>
                                        <ComboBoxItem>20</ComboBoxItem>
                                        <ComboBoxItem>25</ComboBoxItem>
                                        <ComboBoxItem>30</ComboBoxItem>
                                        <ComboBoxItem>35</ComboBoxItem>
                                        <ComboBoxItem>40</ComboBoxItem>
                                        <ComboBoxItem>45</ComboBoxItem>
                                        <ComboBoxItem>50</ComboBoxItem>
                                        <ComboBoxItem>55</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Weekly days -->
                                <StackPanel x:Name="WeeklyBlock" Orientation="Vertical" Margin="0,0,0,5" Visibility="Collapsed">
                                    <Label Content="Opakovat v dny:"/>
                                    <WrapPanel>
                                        <CheckBox x:Name="MonCheck" Content="Po" Tag="Mon" Margin="2"/>
                                        <CheckBox x:Name="TueCheck" Content="Út" Tag="Tue" Margin="2"/>
                                        <CheckBox x:Name="WedCheck" Content="St" Tag="Wed" Margin="2"/>
                                        <CheckBox x:Name="ThuCheck" Content="Čt" Tag="Thu" Margin="2"/>
                                        <CheckBox x:Name="FriCheck" Content="Pá" Tag="Fri" Margin="2"/>
                                        <CheckBox x:Name="SatCheck" Content="So" Tag="Sat" Margin="2"/>
                                        <CheckBox x:Name="SunCheck" Content="Ne" Tag="Sun" Margin="2"/>
                                    </WrapPanel>
                                </StackPanel>

                                <!-- Monthly day -->
                                <StackPanel x:Name="MonthlyBlock" Orientation="Horizontal" Margin="0,0,0,5" Visibility="Collapsed">
                                    <Label Content="Den v měsíci:" Width="100"/>
                                    <TextBox x:Name="MonthlyDayText" Width="60"/>
                                </StackPanel>

                                <!-- Hourly minute -->
                                <StackPanel x:Name="HourlyBlock" Orientation="Horizontal" Margin="0,0,0,5" Visibility="Collapsed">
                                    <Label Content="Minuta (0-59):" Width="100"/>
                                    <ComboBox x:Name="HourlyMinuteCombo" Width="70">
                                        <!-- 0..59 -->
                                        <ComboBoxItem>0</ComboBoxItem>
                                        <ComboBoxItem>1</ComboBoxItem>
                                        <ComboBoxItem>2</ComboBoxItem>
                                        <ComboBoxItem>3</ComboBoxItem>
                                        <ComboBoxItem>4</ComboBoxItem>
                                        <ComboBoxItem>5</ComboBoxItem>
                                        <ComboBoxItem>6</ComboBoxItem>
                                        <ComboBoxItem>7</ComboBoxItem>
                                        <ComboBoxItem>8</ComboBoxItem>
                                        <ComboBoxItem>9</ComboBoxItem>
                                        <ComboBoxItem>10</ComboBoxItem>
                                        <ComboBoxItem>11</ComboBoxItem>
                                        <ComboBoxItem>12</ComboBoxItem>
                                        <ComboBoxItem>13</ComboBoxItem>
                                        <ComboBoxItem>14</ComboBoxItem>
                                        <ComboBoxItem>15</ComboBoxItem>
                                        <ComboBoxItem>16</ComboBoxItem>
                                        <ComboBoxItem>17</ComboBoxItem>
                                        <ComboBoxItem>18</ComboBoxItem>
                                        <ComboBoxItem>19</ComboBoxItem>
                                        <ComboBoxItem>20</ComboBoxItem>
                                        <ComboBoxItem>21</ComboBoxItem>
                                        <ComboBoxItem>22</ComboBoxItem>
                                        <ComboBoxItem>23</ComboBoxItem>
                                        <ComboBoxItem>24</ComboBoxItem>
                                        <ComboBoxItem>25</ComboBoxItem>
                                        <ComboBoxItem>26</ComboBoxItem>
                                        <ComboBoxItem>27</ComboBoxItem>
                                        <ComboBoxItem>28</ComboBoxItem>
                                        <ComboBoxItem>29</ComboBoxItem>
                                        <ComboBoxItem>30</ComboBoxItem>
                                        <ComboBoxItem>31</ComboBoxItem>
                                        <ComboBoxItem>32</ComboBoxItem>
                                        <ComboBoxItem>33</ComboBoxItem>
                                        <ComboBoxItem>34</ComboBoxItem>
                                        <ComboBoxItem>35</ComboBoxItem>
                                        <ComboBoxItem>36</ComboBoxItem>
                                        <ComboBoxItem>37</ComboBoxItem>
                                        <ComboBoxItem>38</ComboBoxItem>
                                        <ComboBoxItem>39</ComboBoxItem>
                                        <ComboBoxItem>40</ComboBoxItem>
                                        <ComboBoxItem>41</ComboBoxItem>
                                        <ComboBoxItem>42</ComboBoxItem>
                                        <ComboBoxItem>43</ComboBoxItem>
                                        <ComboBoxItem>44</ComboBoxItem>
                                        <ComboBoxItem>45</ComboBoxItem>
                                        <ComboBoxItem>46</ComboBoxItem>
                                        <ComboBoxItem>47</ComboBoxItem>
                                        <ComboBoxItem>48</ComboBoxItem>
                                        <ComboBoxItem>49</ComboBoxItem>
                                        <ComboBoxItem>50</ComboBoxItem>
                                        <ComboBoxItem>51</ComboBoxItem>
                                        <ComboBoxItem>52</ComboBoxItem>
                                        <ComboBoxItem>53</ComboBoxItem>
                                        <ComboBoxItem>54</ComboBoxItem>
                                        <ComboBoxItem>55</ComboBoxItem>
                                        <ComboBoxItem>56</ComboBoxItem>
                                        <ComboBoxItem>57</ComboBoxItem>
                                        <ComboBoxItem>58</ComboBoxItem>
                                        <ComboBoxItem>59</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Minutely interval -->
                                <StackPanel x:Name="MinutelyBlock" Orientation="Horizontal" Margin="0,0,0,5" Visibility="Collapsed">
                                    <Label Content="Interval (minuty):" Width="120"/>
                                    <ComboBox x:Name="MinutelyIntervalCombo" Width="80" IsEditable="False">
                                        <ComboBoxItem>1</ComboBoxItem>
                                        <ComboBoxItem>2</ComboBoxItem>
                                        <ComboBoxItem>3</ComboBoxItem>
                                        <ComboBoxItem>5</ComboBoxItem>
                                        <ComboBoxItem>10</ComboBoxItem>
                                        <ComboBoxItem>15</ComboBoxItem>
                                        <ComboBoxItem>20</ComboBoxItem>
                                        <ComboBoxItem>30</ComboBoxItem>
                                        <ComboBoxItem>60</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                            </StackPanel>
                        </GroupBox>

                        <!-- Actions -->
                        <GroupBox Header="Akce" Margin="0,5,0,5">
                            <DockPanel Margin="8">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <Button x:Name="AddActionBtn" Content="Přidat" Width="70" Margin="0,0,5,0" Click="AddAction_Click"/>
                                    <Button x:Name="RemoveActionBtn" Content="Odebrat" Width="75" Margin="0,0,5,0" Click="RemoveAction_Click"/>
                                    <Button x:Name="MoveActionUpBtn" Content="↑" Width="40" Margin="0,0,5,0" Click="MoveActionUp_Click"/>
                                    <Button x:Name="MoveActionDownBtn" Content="↓" Width="40" Click="MoveActionDown_Click"/>
                                </StackPanel>

                                <!-- Scrollable actions grid -->
                                <DataGrid x:Name="V3ActionsGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="False"
                                          GridLinesVisibility="Vertical"
                                          RowHeaderWidth="0"
                                          Height="260"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridComboBoxColumn Header="Type" Width="100"
                                                                SelectedItemBinding="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <DataGridComboBoxColumn.ItemsSource>
                                                <x:Array Type="{x:Type sys:String}">
                                                    <sys:String>RunProgram</sys:String>
                                                    <sys:String>WriteFile</sys:String>
                                                </x:Array>
                                            </DataGridComboBoxColumn.ItemsSource>
                                        </DataGridComboBoxColumn>

                                        <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="*"/>
                                        <DataGridTextColumn Header="Args"     Width="150" Binding="{Binding Args,     Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        
                                        <DataGridTextColumn Header="Contents" Width="220" Binding="{Binding Contents, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <DataGridCheckBoxColumn Header="Append" Width="70" Binding="{Binding Append, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="Clear" Content="Clear" Margin="5" Width="90" Click="Clear_Click"/>
            <Button Name="Load" Content="Load" Margin="5" Width="90" Click="Load_Click"/>
            <Button Name="Save" Content="Save" Margin="5" Width="90" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Window>
